{
  "name": "osm-apps-catalog",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ToastHawaii/osm-apps-catalog"
  },
  "author": "ToastHawaii",
  "license": "AGPL",
  "bugs": {
    "url": "https://github.com/ToastHawaii/osm-apps-catalog/issues"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "@fontsource-variable/noto-sans": "5.2.10",
    "@hugeicons/core-free-icons": "4.1.4",
    "@hugeicons/react": "1.1.6",
    "@nozbe/microfuzz": "1.0.0",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toggle": "1.1.10",
    "@tailwindcss/vite": "4.3.0",
    "@vercel/ncc": "0.44.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "eld": "2.0.3",
    "embla-carousel-autoplay": "8.6.0",
    "embla-carousel-react": "8.6.0",
    "i18next": "26.2.0",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-client": "1.11.4",
    "lodash": "4.18.1",
    "md5": "2.3.0",
    "moment-timezone": "0.6.2",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "17.0.8",
    "react-router": "7.15.1",
    "sanitize-html": "2.17.4",
    "sass": "1.97.2",
    "sitemap": "9.0.1",
    "slim-select": "2.10.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "ua-parser-js": "2.0.10",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@github/local-action": "7.0.1",
    "@nabla/vite-plugin-eslint": "3.0.1",
    "@types/lodash": "4.17.24",
    "@types/md5": "2.3.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "globals": "16.5.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "shadcn": "4.7.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.16"
  },
  "scripts": {
    "build": "cp docs/sitemap.xml public && cp docs/api/apps/*.json public/api/apps && npm run lint && npm run app:build && npm run actions:build",
    "app:start": "vite",
    "app:build": "vite build",
    "actions:build": "npm run actions:collect-osm-apps:build && npm run actions:collect-osm-apps-translations:build",
    "actions:collect-osm-apps:start": "npx local-action actions/collect-osm-apps main.ts .env",
    "actions:collect-osm-apps:build": "npx ncc build actions/collect-osm-apps/index.ts -o dist/actions/collect-osm-apps",
    "actions:collect-osm-apps-translations:start": "npx local-action actions/collect-osm-apps-translations main.ts .env",
    "actions:collect-osm-apps-translations:build": "npx ncc build actions/collect-osm-apps-translations/index.ts -o dist/actions/collect-osm-apps-translations",
    "lint": "eslint src && prettier --check 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint src --fix && prettier --write 'src/**/*.{ts,tsx}'",
    "type-check": "tsc"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
